# =============================================================================
# Notesy stack — environment configuration
#
# Copy to `.env` and fill in real values:
#   cp .env.example .env
#
# Variables marked AUTHENTIK are only consumed by docker-compose.authentik.yml.
# Variables marked LEGACY are only consumed by docker-compose.legacy.yml.
# Everything else is shared.
# =============================================================================

# --- Shared ---------------------------------------------------------------

# Hostname users will hit in their browser. Must resolve to this host.
# Used by Caddy + oauth2-proxy redirect URLs.
DNS_NAME=notes.example.local

# Host directory where persistent data lives. Three subdirs are created
# under it: share/ (notes + uploads), database/ (filebrowser DB),
# session-bridge/ (transfer-code DB, AUTHENTIK only).
DATA_DIR=/opt/notesy

# Space-separated list of FileBrowser usernames to provision on first start.
# In legacy mode they all get FB_DEFAULT_USER_PASSWORD.
# In Authentik mode they must match Authentik usernames.
FB_USERS=alice bob

# Branding shown in FileBrowser's UI.
FB_BRANDING=Notes
FB_BRANDING_THEME=dark

# OnlyOffice ↔ FileBrowser shared JWT secret.
# Generate with: openssl rand -hex 32
ONLYOFFICE_JWT_SECRET=replace-me

# CodiMD session signing secret.
# Generate with: openssl rand -hex 24
CMD_SESSION_SECRET=replace-me


# --- LEGACY (docker-compose.legacy.yml) -----------------------------------

# Default password assigned to every user in FB_USERS on first run.
# Users can change it after logging in.
FB_DEFAULT_USER_PASSWORD=changeme


# --- AUTHENTIK (docker-compose.authentik.yml) -----------------------------

# session-bridge HMAC key for the long-lived transfer cookie.
# Generate with: openssl rand -hex 32
SESSION_BRIDGE_SECRET=replace-me

# OIDC client credentials from Authentik:
#   Applications → Providers → <your-provider> → Protocol settings
OIDC_CLIENT_ID=replace-me
OIDC_CLIENT_SECRET=replace-me

# OIDC issuer URL — typically:
#   https://<your-authentik-host>/application/o/<application-slug>/
# Trailing slash matters.
OIDC_ISSUER_URL=https://auth.example.local/application/o/notesy/

# oauth2-proxy cookie signing secret. MUST be exactly 16, 24, or 32 bytes.
# Generate with: openssl rand -base64 32 | head -c 32
OAUTH2_PROXY_COOKIE_SECRET=replace-me-32-bytes-long-exactly
